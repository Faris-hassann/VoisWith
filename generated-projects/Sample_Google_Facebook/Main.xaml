<?xml version="1.0" encoding="utf-8"?>
<Activity x:Class="Main" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="http://schemas.uipath.com/workflow/activities">
  <Sequence DisplayName="Sample_Google_Facebook">
    <!-- step-1: Open Google -->
    <ui:OpenBrowser Url="https://www.google.com" BrowserType="Chrome" />
    <!-- step-2: Search Facebook -->
    <ui:TypeInto Text="Facebook" Selector="&lt;webctrl tag='TEXTAREA' name='q' /&gt;" />
    <!-- step-3: Type password | REQUIRES USER CONFIRMATION -->
    <ui:TypeInto Text="[REPLACE_WITH_SECURE_CREDENTIAL]" Selector="&lt;webctrl tag='INPUT' id='pass' /&gt;" />
  </Sequence>
</Activity>
